# GitHub App OAuth (required for accounts and private repositories)
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
AUTH_SECRET=
# Verifies GitHub webhook deliveries used to flag tracked PRs for refresh.
GITHUB_WEBHOOK_SECRET=

# Optional hosted database. Without these, RepoLens uses .data/repolens.db locally.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional anonymous public-repository rate-limit token.
GITHUB_TOKEN=

# Optional AI-enriched feature tracing. Core findings remain deterministic.
OPENAI_API_KEY=
OPENAI_TRACE_MODEL=
OPENAI_API_BASE_URL=

ANALYSIS_TTL_MS=
